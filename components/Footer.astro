---
import { ENDPOINTS, CATEGORY_LABELS } from "@kyzen/shared";

const categories = ["ai", "tools", "utility", "fun", "image"] as const;

const grouped = categories.map((category) => ({
  key: category,
  label: CATEGORY_LABELS[category],
  endpoints: ENDPOINTS.filter((e) => e.category === category),
}));

const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="container-page py-12">
    <div class="grid grid-cols-2 gap-4 sm:gap-6 sm:grid-cols-3 md:grid-cols-6">
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2 font-display text-base sm:text-lg font-semibold text-text">
          <span class="flex h-7 w-7 items-center justify-center rounded-md bg-primary text-sm font-bold text-background">K</span>
          Kyzen API
        </a>
        <p class="mt-3 max-w-xs text-sm text-muted">
          Simple. Fast. Reliable. A personal REST API platform for developers, bot creators, and hobby projects.
        </p>
      </div>

      {grouped.map((group) => (
        <div>
          <h3 class="font-display text-xs sm:text-sm font-semibold text-text">{group.label}</h3>
          <ul class="mt-3 space-y-2">
            {group.endpoints.map((endpoint) => (
              <li>
                <a href={`/docs#${endpoint.path.split("/").pop()}`} class="font-mono text-xs text-muted hover:text-primary">
                  <span class="method-get mr-1">GET</span>{endpoint.path}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border pt-6 text-sm text-muted sm:flex-row">
      <p>&copy; {year} Kyzen API. All rights reserved.</p>
      <p class="font-mono text-xs">Simple. Fast. Reliable.</p>
    </div>
  </div>
</footer>
