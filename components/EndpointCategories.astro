---
import { ENDPOINTS, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS } from "@kyzen/shared";

const categories = ["ai", "tools", "utility", "image", "fun"] as const;

const groups = categories.map((category) => ({
  key: category,
  label: CATEGORY_LABELS[category],
  description: CATEGORY_DESCRIPTIONS[category],
  count: ENDPOINTS.filter((e) => e.category === category).length,
}));
---

<section class="container-page py-12 sm:py-16 md:py-24">
  <div class="max-w-2xl">
    <h2 class="font-display text-2xl font-semibold text-text sm:text-3xl">Endpoint categories</h2>
    <p class="mt-3 text-muted">Every endpoint is grouped into one of five categories.</p>
  </div>

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
    {groups.map((group) => (
      <a href={`/docs#${group.key}`} class="card group p-6 transition-colors hover:border-primary/50">
        <div class="flex items-center justify-between">
          <h3 class="font-display text-lg font-semibold text-text">{group.label}</h3>
          <span class="pill">{group.count}</span>
        </div>
        <p class="mt-2 text-sm text-muted">{group.description}</p>
        <span class="mt-4 inline-block text-sm font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
          View endpoints →
        </span>
      </a>
    ))}
  </div>
</section>
