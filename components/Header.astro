---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/docs", label: "Docs" },
  { href: "/playground", label: "Playground" },
  { href: "/status", label: "Status" },
  { href: "/about", label: "About" },
];

const currentPath = new URL(Astro.request.url).pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur">
  <div class="container-page flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-display text-base sm:text-lg font-semibold text-text flex-shrink-0">
      <span class="flex h-7 w-7 items-center justify-center rounded-md bg-primary text-sm font-bold text-background">K</span>
      Kyzen API
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => {
        const active = currentPath === link.href;
        return (
          <a
            href={link.href}
            class={`rounded-md px-3 py-2 text-sm font-medium transition-colors ${
              active ? "text-primary" : "text-muted hover:text-text"
            }`}
            aria-current={active ? "page" : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/docs" class="hidden text-sm font-medium text-muted hover:text-text sm:block">
        Docs
      </a>
      <a href="/playground" class="btn-primary text-sm">
        Try the API
      </a>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav class="container-page flex gap-4 overflow-x-auto border-t border-border py-2 md:hidden">
    {navLinks.map((link) => {
      const active = currentPath === link.href;
      return (
        <a
          href={link.href}
          class={`whitespace-nowrap text-sm font-medium ${active ? "text-primary" : "text-muted"}`}
        >
          {link.label}
        </a>
      );
    })}
  </nav>
</header>
