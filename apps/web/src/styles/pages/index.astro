---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import EndpointCategories from "../components/EndpointCategories.astro";
---

<Layout title="Kyzen API — Simple. Fast. Reliable.">
  <Hero />
  <Features />
  <EndpointCategories />

  <section class="container-page py-16 sm:py-24">
    <div class="card flex flex-col items-start justify-between gap-6 p-8 sm:flex-row sm:items-center">
      <div>
        <h2 class="font-display text-xl font-semibold text-text sm:text-2xl">Ready to try it?</h2>
        <p class="mt-2 max-w-md text-sm text-muted">
          Open the playground, pick an endpoint, and see a real response in seconds — no signup required.
        </p>
      </div>
      <a href="/playground" class="btn-primary whitespace-nowrap">Open Playground</a>
    </div>
  </section>
</Layout>
