---
import Layout from "../layouts/Layout.astro";
import { ENDPOINTS, CATEGORY_LABELS, API_BASE_URL } from "@kyzen/shared";

const endpointsJson = JSON.stringify(ENDPOINTS);
const categoryLabelsJson = JSON.stringify(CATEGORY_LABELS);
---

<Layout title="Playground" description="Try every Kyzen API endpoint directly in your browser.">
  <div class="container-page py-12 sm:py-16">
    <div class="max-w-2xl">
      <h1 class="font-display text-3xl font-semibold text-text sm:text-4xl">Playground</h1>
      <p class="mt-3 text-muted">
        Pick an endpoint, fill in the parameters, and send a real request to
        <code class="font-mono text-primary">{API_BASE_URL}</code>.
      </p>
    </div>

    <div class="mt-8 grid gap-4 sm:gap-6 grid-cols-1 lg:grid-cols-2">
      <!-- Request builder -->
      <div class="card p-4 sm:p-6">
        <label class="block text-sm font-medium text-text" for="endpoint-select">Endpoint</label>
        <select id="endpoint-select" class="mt-2 w-full rounded-md border border-border bg-surface-2 px-3 py-2 font-mono text-sm text-text focus-visible:outline-2 focus-visible:outline-primary">
        </select>

        <p id="endpoint-description" class="mt-3 text-sm text-muted"></p>

        <div id="params-container" class="mt-4 space-y-3"></div>

        <button id="execute-button" type="button" class="btn-primary mt-6 w-full sm:w-auto">
          Execute Request
        </button>

        <div class="mt-4">
          <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-muted">Request URL</p>
          <div class="card overflow-x-auto bg-surface-2 p-3">
            <code id="request-url" class="font-mono text-xs text-text break-all"></code>
          </div>
        </div>
      </div>

      <!-- Response viewer -->
      <div class="card flex flex-col p-4 sm:p-6">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-wide text-muted">Response</p>
          <div class="flex items-center gap-3">
            <span id="response-status" class="font-mono text-xs text-muted"></span>
            <button id="copy-button" type="button" class="pill hover:border-primary/50 hover:text-primary">
              Copy
            </button>
          </div>
        </div>
        <pre class="mt-3 flex-1 overflow-auto rounded-md bg-surface-2 p-4 text-sm leading-relaxed"><code id="response-output" class="font-mono text-muted">Run a request to see the response here.</code></pre>
      </div>
    </div>
  </div>
</Layout>

<script type="module" define:vars={{ endpointsJson, categoryLabelsJson, API_BASE_URL }}>
  const endpoints = JSON.parse(endpointsJson);
  const categoryLabels = JSON.parse(categoryLabelsJson);

  const select = document.getElementById("endpoint-select");
  const descriptionEl = document.getElementById("endpoint-description");
  const paramsContainer = document.getElementById("params-container");
  const requestUrlEl = document.getElementById("request-url");
  const executeButton = document.getElementById("execute-button");
  const responseOutput = document.getElementById("response-output");
  const responseStatus = document.getElementById("response-status");
  const copyButton = document.getElementById("copy-button");

  // Group endpoints by category for <optgroup> rendering.
  const groups = new Map();
  for (const endpoint of endpoints) {
    if (!groups.has(endpoint.category)) groups.set(endpoint.category, []);
    groups.get(endpoint.category).push(endpoint);
  }

  for (const [category, items] of groups) {
    const optgroup = document.createElement("optgroup");
    optgroup.label = categoryLabels[category] ?? category;
    for (const endpoint of items) {
      const option = document.createElement("option");
      option.value = endpoint.path;
      option.textContent = `${endpoint.method} ${endpoint.path}`;
      optgroup.appendChild(option);
    }
    select.appendChild(optgroup);
  }

  function getEndpoint(path) {
    return endpoints.find((e) => e.path === path);
  }

  function renderParams(endpoint) {
    paramsContainer.innerHTML = "";
    descriptionEl.textContent = endpoint.description;

    for (const param of endpoint.params) {
      const wrapper = document.createElement("div");

      const label = document.createElement("label");
      label.className = "block text-sm font-medium text-text";
      label.textContent = param.name + (param.required ? " *" : "");
      label.setAttribute("for", `param-${param.name}`);

      const input = document.createElement("input");
      input.id = `param-${param.name}`;
      input.name = param.name;
      input.type = param.type === "number" ? "number" : "text";
      input.placeholder = param.example !== undefined ? String(param.example) : "";
      input.className =
        "mt-1 w-full rounded-md border border-border bg-surface-2 px-3 py-2 font-mono text-sm text-text focus-visible:outline-2 focus-visible:outline-primary";
      input.dataset.paramType = param.type;
      input.addEventListener("input", updateRequestUrl);

      const help = document.createElement("p");
      help.className = "mt-1 text-xs text-muted";
      help.textContent = param.description;

      wrapper.append(label, input, help);
      paramsContainer.appendChild(wrapper);
    }

    updateRequestUrl();
  }

  function buildUrl(endpoint) {
    const url = new URL(API_BASE_URL + endpoint.path);
    const inputs = paramsContainer.querySelectorAll("input");
    inputs.forEach((input) => {
      if (input.value.trim() !== "") {
        url.searchParams.set(input.name, input.value.trim());
      }
    });
    return url;
  }

  function updateRequestUrl() {
    const endpoint = getEndpoint(select.value);
    if (!endpoint) return;
    requestUrlEl.textContent = `${endpoint.method} ${buildUrl(endpoint).toString()}`;
  }

  async function executeRequest() {
    const endpoint = getEndpoint(select.value);
    if (!endpoint) return;

    const url = buildUrl(endpoint);

    executeButton.disabled = true;
    executeButton.textContent = "Sending...";
    responseStatus.textContent = "";
    responseOutput.textContent = "Loading...";
    responseOutput.className = "font-mono text-muted";

    try {
      const start = performance.now();
      const res = await fetch(url.toString(), { method: endpoint.method });
      const duration = Math.round(performance.now() - start);
      const data = await res.json();

      responseStatus.textContent = `${res.status} · ${duration}ms`;
      responseStatus.className = `font-mono text-xs ${res.ok ? "text-success" : "text-red-400"}`;
      responseOutput.textContent = JSON.stringify(data, null, 2);
      responseOutput.className = "font-mono text-text";
    } catch (err) {
      responseStatus.textContent = "Network error";
      responseStatus.className = "font-mono text-xs text-red-400";
      responseOutput.textContent =
        "Could not reach the API. If you're running this locally, make sure the worker is running and CORS is enabled.\n\n" +
        String(err);
      responseOutput.className = "font-mono text-muted";
    } finally {
      executeButton.disabled = false;
      executeButton.textContent = "Execute Request";
    }
  }

  copyButton.addEventListener("click", async () => {
    await navigator.clipboard.writeText(responseOutput.textContent ?? "");
    copyButton.textContent = "Copied!";
    setTimeout(() => (copyButton.textContent = "Copy"), 1500);
  });

  select.addEventListener("change", () => renderParams(getEndpoint(select.value)));
  executeButton.addEventListener("click", executeRequest);

  // Pre-select endpoint from ?endpoint= query param (linked from the docs page).
  const preselected = new URLSearchParams(window.location.search).get("endpoint");
  if (preselected && endpoints.some((e) => e.path === preselected)) {
    select.value = preselected;
  }

  renderParams(getEndpoint(select.value));
</script>
